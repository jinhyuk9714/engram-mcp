{
  "name": "@jinhyuk9714/engram-mcp",
  "version": "1.2.0",
  "license": "Apache-2.0",
  "description": "에이전트 장기 컨텍스트를 위한 파편 기반 기억 MCP 서버",
  "main": "server.js",
  "type": "module",
  "bin": {
    "engram-mcp": "./bin/engram-mcp.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "lib/",
    "assets/images/",
    "server.js",
    "README.md",
    "README.en.md",
    "README.simple.md",
    "INSTALL.md",
    "INSTALL.en.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    ".env.example",
    "scripts/setup.sh"
  ],
  "scripts": {
    "start": "node ./bin/engram-mcp.js serve",
    "lint": "eslint .",
    "test": "LOG_DIR=tmp/test-logs NODE_ENV=test node --test tests/unit/*.test.js tests/integration/pipeline-overhaul.test.js tests/integration/stdio-explicit-db.test.js",
    "test:db": "LOG_DIR=tmp/test-logs NODE_ENV=test node --test tests/integration/temporal.test.js tests/integration/stdio-explicit-db.test.js",
    "test:e2e:docker": "LOG_DIR=tmp/test-logs NODE_ENV=test node --test tests/e2e/docker-bootstrap.test.js",
    "backfill:embeddings": "node lib/memory/backfill-embeddings.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ioredis": "^5.9.3",
    "js-tiktoken": "^1.0.21",
    "node-fetch": "^3.3.2",
    "openai": "^6.21.0",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
